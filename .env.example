# あなたのBase(EVM)ウォレットアドレス（USDCの受取先）
EVM_ADDRESS=0xYOUR_WALLET_ADDRESS

# ネットワーク設定
NETWORK=eip155:8453

# サーバー設定
HOST=0.0.0.0
PORT=4024

# CDP Facilitator
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# RapidAPI proxy secret (for RapidAPI bypass)
RAPIDAPI_PROXY_SECRET=

# Internal key (for MCP Gateway bypass)
INTERNAL_KEY=

# Solana support (optional - set to Solana wallet address to enable)
SOLANA_PAY_TO=

# Facilitator URL (default: https://x402.org/facilitator)
# FACILITATOR_URL=
